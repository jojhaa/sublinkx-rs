FRONTEND_PORT=3000

# Fixed Docker bridge subnet. Change it if it conflicts with existing Docker/VPN/LAN networks.
SUBLINKX_DOCKER_SUBNET=172.31.88.0/24

# Published images.
BACKEND_IMAGE=docker.io/jojhaa/sublinkx-rs-backend:latest
FRONTEND_IMAGE=docker.io/jojhaa/sublinkx-rs-frontend:latest

# Local host directories mounted into the backend container.
BACKEND_DATA_DIR=./docker-data/backend
MIHOMO_CORE_DIR=./docker-data/mihomo

# Database. SQLite is the default and stores data in BACKEND_DATA_DIR.
DATABASE_URL=sqlite:///app/data/app.db

# Optional MySQL service. Enable both lines below when you want Docker Compose to run MySQL.
# COMPOSE_PROFILES=mysql
# DATABASE_URL=mysql://sublinkx:sublinkx_password@mysql:3306/sublinkx
#
# Existing local/host MySQL. Do not enable COMPOSE_PROFILES=mysql; point the backend
# container to host.docker.internal instead. On Linux this compose file maps it via
# host-gateway, and on Docker Desktop it is built in.
# DATABASE_URL=mysql://sublinkx:sublinkx_password@host.docker.internal:3306/sublinkx
MYSQL_IMAGE=mysql:8.4
MYSQL_DATABASE=sublinkx
MYSQL_USER=sublinkx
MYSQL_PASSWORD=sublinkx_password
MYSQL_ROOT_PASSWORD=sublinkx_root_password
MYSQL_DATA_DIR=./docker-data/mysql

# Change this to a long random value before exposing the service.
JWT_SECRET=change-me-in-production
JWT_EXP_HOURS=24

# First login defaults. The app forces changing both username and password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456
